parameters:
  level: 6
  paths:
    - web/modules/contrib/analyze_ai_brand_voice/src/
  # Drupal root directory
  drupal:
    drupal_root: web
  # Report deprecations and basic analysis errors
  customRulesetUsed: true
  reportUnmatchedIgnoredErrors: false

# Don't include extension files manually - phpstan/extension-installer handles this automatically