<?php

/**
 * @file
 * Contains analyze_ai_brand_voice.module.
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Link;
use Drupal\Core\Url;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_entity_update().
 */
function analyze_ai_brand_voice_entity_update(EntityInterface $entity) {
  if (_analyze_ai_brand_voice_is_supported_entity($entity)) {
    \Drupal::service('analyze_ai_brand_voice.storage')->deleteScores($entity);
  }
}

/**
 * Implements hook_entity_delete().
 */
function analyze_ai_brand_voice_entity_delete(EntityInterface $entity) {
  if (_analyze_ai_brand_voice_is_supported_entity($entity)) {
    \Drupal::service('analyze_ai_brand_voice.storage')->deleteScores($entity);
  }
}

/**
 * Helper function to check if an entity should be analyzed for brand voice.
 *
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   The entity to check.
 *
 * @return bool
 *   TRUE if the entity should be analyzed, FALSE otherwise.
 */
function _analyze_ai_brand_voice_is_supported_entity(EntityInterface $entity): bool {
  // Check if this entity type/bundle has brand voice analysis enabled.
  $config = \Drupal::config('analyze.settings');
  $status = $config->get('status') ?? [];

  $entity_type_id = $entity->getEntityTypeId();
  $bundle = $entity->bundle();

  return isset($status[$entity_type_id][$bundle]['brand_voice_analyzer']);
}

/**
 * Implements hook_views_pre_render().
 */
function analyze_ai_brand_voice_views_pre_render(ViewExecutable $view) {
  // Add settings link to the brand voice analysis view header.
  if ($view->id() === 'ai_brand_voice_analysis' && $view->current_display === 'page_1') {
    $options = [
      'area_text_custom' => [
        'id' => 'area_text_custom',
        'table' => 'views',
        'field' => 'area_text_custom',
        'plugin_id' => 'text_custom',
        'empty' => FALSE,
        'content' => '',
      ],
    ];

    // Build the settings link if user has permission.
    $current_user = \Drupal::currentUser();
    if ($current_user->hasPermission('administer analyze settings')) {
      $settings_url = Url::fromRoute('analyze_ai_brand_voice.settings');
      if ($settings_url->access()) {
        $link = Link::fromTextAndUrl(t('Configure settings'), $settings_url);
        $link = $link->toRenderable();
        $link['#attributes']['class'][] = 'button';
        $link['#attributes']['class'][] = 'button--small';

        // Render the link and add it to the header.
        $renderer = \Drupal::service('renderer');
        $rendered_link = $renderer->renderRoot($link);
        $options['area_text_custom']['content'] = '<div class="form-actions">' . $rendered_link . '</div>';

        // Set the header option.
        $view->display_handler->setOption('header', $options);
      }
    }
  }
}
