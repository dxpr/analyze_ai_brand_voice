<?php

/**
 * @file
 * Contains analyze_ai_brand_voice.module.
 */

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_entity_update().
 */
function analyze_ai_brand_voice_entity_update(EntityInterface $entity) {
  if (_analyze_ai_brand_voice_is_supported_entity($entity)) {
    \Drupal::service('analyze_ai_brand_voice.storage')->deleteScores($entity);
  }
}

/**
 * Implements hook_entity_delete().
 */
function analyze_ai_brand_voice_entity_delete(EntityInterface $entity) {
  if (_analyze_ai_brand_voice_is_supported_entity($entity)) {
    \Drupal::service('analyze_ai_brand_voice.storage')->deleteScores($entity);
  }
}

/**
 * Helper function to check if an entity should be analyzed for brand voice.
 *
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   The entity to check.
 *
 * @return bool
 *   TRUE if the entity should be analyzed, FALSE otherwise.
 */
function _analyze_ai_brand_voice_is_supported_entity(EntityInterface $entity): bool {
  // Check if this entity type/bundle has brand voice analysis enabled.
  $config = \Drupal::config('analyze.settings');
  $status = $config->get('status') ?? [];

  $entity_type_id = $entity->getEntityTypeId();
  $bundle = $entity->bundle();

  return isset($status[$entity_type_id][$bundle]['brand_voice_analyzer']);
}
